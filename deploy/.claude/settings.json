{
  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(wp:*)",
      "Bash(php:*)",
      "Bash(chmod:*)",
      "Bash(ssh:*)",
      "Bash(scp:*)",
      "Bash(rsync:*)",
      "Bash(curl:*)",
      "Bash(unzip:*)",
      "Bash(ffmpeg:*)",
      "Bash(.claude/scripts/*)",
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch"
    ],
    "deny": [
      "Read(./.env*)",
      "Read(./secrets/**)",
      "Read(./.env.example)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/PreToolUse/block-dangerous-commands.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/PreToolUse/block-protected-files.sh"
          }
        ]
      }
    ]
  }
}
